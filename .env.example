# ---------------------------------------------------------------------------
# Cloud Alliance Score — required configuration
# Copy to `.env` and fill in your keys:  cp .env.example .env
# ---------------------------------------------------------------------------

# Anthropic Claude — the LLM behind every scoring sub-agent. (required)
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Tavily — web search used to gather evidence per dimension. (required)
# Get one at https://app.tavily.com/
TAVILY_API_KEY=tvly-...

# LangSmith — tracing / observability for the LangGraph run. (optional but recommended)
# Get one at https://smith.langchain.com/  → Settings → API Keys
LANGSMITH_API_KEY=lsv2_...

# ---------------------------------------------------------------------------
# Optional tuning — sensible defaults are applied if unset.
# ---------------------------------------------------------------------------

# Enable LangSmith tracing (true/false). Requires LANGSMITH_API_KEY.
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=cloud-alliance-score
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Claude model id used by sub-agents.
CAS_MODEL=claude-sonnet-4-6

# Max Tavily results gathered per dimension.
CAS_SEARCH_MAX_RESULTS=5

# Sampling temperature for scoring (lower = more deterministic).
CAS_TEMPERATURE=0.0

# Tavily retry / exponential backoff on search failures.
CAS_SEARCH_RETRIES=3
CAS_SEARCH_BACKOFF_BASE=0.5
CAS_SEARCH_BACKOFF_MAX=8.0

# Disk cache — saves Tavily + Anthropic credits on repeat runs.
# Cached per (company, dimension, model) with the TTL below (default 24h).
CAS_CACHE_ENABLED=true
CAS_CACHE_DIR=.cache/cloud_alliance_score
CAS_CACHE_TTL_SECONDS=86400

# --- Public demo guardrails (for a hosted/public deployment) ----------------
# Set CAS_DEMO_MODE=true on a public deploy: serves a free curated gallery and
# caps live scoring so visitors can't burn your API credits.
CAS_DEMO_MODE=false
CAS_DEMO_DAILY_CAP=25
CAS_DEMO_SESSION_CAP=3

# On Vercel, the daily cap uses Upstash Redis (shared across serverless
# instances). These are injected automatically by the Vercel Upstash
# integration — you don't set them by hand locally.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
